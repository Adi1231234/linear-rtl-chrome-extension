{
  "name": "linear-rtl-chrome-extension",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Chrome extension that displays right-to-left languages correctly across all of Linear.",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "esbuild src/main.ts --bundle --format=iife --target=chrome120 --outfile=dist/content.js",
    "watch": "npm run build -- --watch"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "typescript": "^5.6.3"
  }
}
