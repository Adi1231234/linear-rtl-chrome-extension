{
  "manifest_version": 3,
  "name": "Linear RTL",
  "version": "2.0.1",
  "description": "Displays right-to-left languages correctly across all of Linear. A line with more than one RTL word becomes RTL.",
  "author": "Adi Aharoni",
  "homepage_url": "https://github.com/Adi1231234/linear-rtl-chrome-extension",
  "minimum_chrome_version": "120",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://linear.app/*"],
      "js": ["dist/content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}
